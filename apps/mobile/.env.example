# Copy to .env.local and fill in to enable the optional integrations.
# All are optional — with none set, the app runs fully offline.
# Expo inlines EXPO_PUBLIC_* vars into the build.

# nag-ai proxy (Phase 2): AI-rewritten snooze copy. See services/nag-ai.
# EXPO_PUBLIC_NAG_AI_ENDPOINT=https://your-proxy.example.com/v1/nag-copy
# EXPO_PUBLIC_NAG_AI_SHARED_SECRET=topsecret

# Supabase sync (Phase 3): see supabase/README.md. The anon key is public
# (RLS gates access), so it's safe to ship in the build.
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
