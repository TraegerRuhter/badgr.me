# Copy to .env.local and fill in to enable the optional integrations.
# All are optional — with none set, the web app runs fully offline.

# nag-ai proxy (Phase 2): AI-rewritten snooze copy. See services/nag-ai.
# VITE_NAG_AI_ENDPOINT=https://your-proxy.example.com/v1/nag-copy
# VITE_NAG_AI_SHARED_SECRET=topsecret

# Supabase sync (Phase 3): see supabase/README.md. The anon key is public
# (RLS gates access), so it's safe to ship in the client bundle.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
