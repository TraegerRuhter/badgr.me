# Copy to .env and fill in to run the proxy. See services/nag-ai/README.md.

# Required — server-side only. NEVER ship this in a client build.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the default small/fast Claude model.
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional — listen port (default 8787).
# PORT=8787

# Optional — abuse deterrence. If set, clients must send
# `Authorization: Bearer <secret>`. Not real auth (see README).
# NAG_AI_SHARED_SECRET=topsecret
